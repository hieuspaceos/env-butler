{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Env Butler",
  "version": "0.1.0",
  "identifier": "com.envbutler.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Env Butler",
        "width": 900,
        "height": 650,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwMTFDNjZGMTk4Mjc0RTMKUldUamRJSVpiOFlSa0Z5WlhYd01YWlJKTDRmNklXaXdhY2dVclUyYlR6SGRwM0JjMWFnNktEZnEK",
      "endpoints": [
        "https://github.com/hieuspaceos/env-butler/releases/latest/download/update.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
